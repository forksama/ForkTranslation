{
  "manifestVersion": 5,
  "id": "com.forktranslation.premiere.audio-prefix-importer",
  "name": "ForkTranslation Audio Prefix Importer",
  "version": "0.1.2",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.6.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "audioPrefixImporterPanel",
      "label": {
        "default": "Audio Prefix Importer"
      },
      "minimumSize": {
        "width": 320,
        "height": 440
      },
      "preferredDockedSize": {
        "width": 430,
        "height": 660
      },
      "preferredFloatingSize": {
        "width": 480,
        "height": 700
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  }
}
