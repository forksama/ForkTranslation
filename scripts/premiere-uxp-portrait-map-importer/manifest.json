{
  "manifestVersion": 5,
  "id": "com.forktranslation.premiere.portrait-map-importer",
  "name": "ForkTranslation Portrait Map Importer",
  "version": "0.1.0",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.6.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "portraitMapImporterPanel",
      "label": {
        "default": "Portrait Map Importer"
      },
      "minimumSize": {
        "width": 340,
        "height": 500
      },
      "preferredDockedSize": {
        "width": 460,
        "height": 760
      },
      "preferredFloatingSize": {
        "width": 520,
        "height": 820
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  }
}
