{
  "manifestVersion": 5,
  "id": "com.forktranslation.premiere.workflow-panel",
  "name": "ForkTranslation Premiere Workflow",
  "version": "0.3.0",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.6.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "workflowPanel",
      "label": {
        "default": "ForkTranslation Workflow"
      },
      "minimumSize": {
        "width": 360,
        "height": 520
      },
      "preferredDockedSize": {
        "width": 520,
        "height": 780
      },
      "preferredFloatingSize": {
        "width": 620,
        "height": 860
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  }
}
