{
  "manifestVersion": 5,
  "id": "com.forktranslation.premiere.image-bottom-pulse",
  "name": "ForkTranslation Image Bottom Pulse",
  "version": "0.1.0",
  "main": "index.html",
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.2.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "imageBottomPulsePanel",
      "label": {
        "default": "Image Bottom Pulse"
      },
      "minimumSize": {
        "width": 320,
        "height": 420
      },
      "preferredDockedSize": {
        "width": 420,
        "height": 620
      },
      "preferredFloatingSize": {
        "width": 460,
        "height": 680
      }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  }
}
