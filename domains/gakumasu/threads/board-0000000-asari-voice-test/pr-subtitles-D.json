      "id": "C0010",
      "order": 10,
      "role": "根绪亚纱里",
      "source": "P0001",
      "sourceRefs": [
        "P0001"
      ],
      "line1": "还有稍微认真的声音，",
      "line2": "都算作今天的课题吧。",
      "lines": [
        "还有稍微认真的声音，",
        "都算作今天的课题吧。"
      ],
      "text": "还有稍微认真的声音，\n都算作今天的课题吧。"
