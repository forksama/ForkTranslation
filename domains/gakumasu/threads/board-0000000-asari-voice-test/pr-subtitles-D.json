      "order": 9,
      "role": "根绪亚纱里",
      "source": "P0001",
      "sourceRefs": [
        "P0001"
      ],
      "line1": "不过，好吧。",
      "line2": "温柔讲解的声音，惊讶的声音，",
      "lines": [
        "不过，好吧。",
        "温柔讲解的声音，惊讶的声音，"
      ],
      "text": "不过，好吧。\n温柔讲解的声音，惊讶的声音，"
