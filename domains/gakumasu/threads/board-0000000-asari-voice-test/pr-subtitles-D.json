      "role": "根绪亚纱里",
      "source": "P0001",
      "sourceRefs": [
        "P0001"
      ],
      "line1": "无论是『初』、N.I.A，",
      "line2": "还是 H.I.F 的选拔考试。",
      "lines": [
        "无论是『初』、N.I.A，",
